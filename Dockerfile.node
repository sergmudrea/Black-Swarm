FROM node:18-alpine AS web-builder
WORKDIR /web
COPY web/package.json web/package-lock.json* ./
RUN npm install
COPY web/ .
RUN npm run build

FROM golang:1.22-alpine AS builder
WORKDIR /src
COPY . .
COPY --from=web-builder /web/build ./web/build
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags="-s -w" -o /swarm ./cmd/swarm

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /swarm /usr/local/bin/swarm
ENTRYPOINT ["/usr/local/bin/swarm"]
